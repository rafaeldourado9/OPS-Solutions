# ============================================================
# CRM White-Label — Environment Variables
# ============================================================

# --- Database (CRM) ---
CRM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@crm-postgres:5432/crm

# --- Redis (db=1 para nao colidir com agents db=0) ---
REDIS_URL=redis://redis:6379/1

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Agents Integration ---
AGENTS_API_URL=http://agent:8000
AGENTS_DIR=/app/shared-agents

# --- WhatsApp Gateway ---
GATEWAY_URL=http://gateway:3000
GATEWAY_API_KEY=

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- MinIO (S3-compatible storage) ---
MINIO_URL=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crm-files

# --- Qdrant (read-only, for RAG document listing) ---
QDRANT_URL=http://qdrant:6333

# --- Gemini (for template analysis) ---
GEMINI_API_KEY=

# --- Email (Resend) ---
# 1. Register free at https://resend.com
# 2. Add your domain and configure DNS TXT + CNAME records (no mailbox needed)
# 3. Get your API key from the Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=OPS Solutions <suporte@ops.solutions.com>

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false
