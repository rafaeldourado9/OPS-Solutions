# ============================================================
# WhatsApp Agent Framework — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# LLM — Google Gemini (primary for complex queries)
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# Redis — Debounce, rate limiting and task tracking
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Qdrant — Semantic memory and RAG
# ------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# Leave empty for a local unauthenticated instance
QDRANT_API_KEY=

# ------------------------------------------------------------
# PostgreSQL — Full conversation history
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/whatsapp_agent

# ------------------------------------------------------------
# WAHA — WhatsApp HTTP API gateway
# ------------------------------------------------------------
WAHA_URL=http://localhost:3000
WAHA_API_KEY=adminops
# URL that WAHA will POST webhooks to (must be reachable from the WAHA container)
WAHA_HOOK_URL=http://host.docker.internal:8000/webhook
# WAHA session name (WAHA Core only supports 'default')
WAHA_SESSION=default
# Dashboard credentials (http://localhost:3000/dashboard)
WAHA_DASHBOARD_USER=admin
WAHA_DASHBOARD_PASSWORD=adminops

# ------------------------------------------------------------
# Ollama — Local models (fallback LLM, embeddings, Whisper, LLaVA)
# ------------------------------------------------------------
OLLAMA_URL=http://localhost:11434

# ------------------------------------------------------------
# Agent — Single agent mode
# ------------------------------------------------------------
AGENT_ID=ops_solutions
AGENT_SESSION=default  # Nome da sessão WAHA (deve bater com o nome criado no dashboard)

# Multi-agent mode (comma-separated; overrides AGENT_ID when set)
# AGENT_IDS=empresa_x,empresa_y

# ------------------------------------------------------------
# Google Calendar — Integration for study_io agent (Maya)
# ------------------------------------------------------------
GOOGLE_CALENDAR_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=

# ------------------------------------------------------------
# CRM — Optional external webhook (leave empty to disable)
# ------------------------------------------------------------
CRM_WEBHOOK_URL=

# ------------------------------------------------------------
# Rate limiting (per chat_id, fixed window)
# ------------------------------------------------------------
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# ------------------------------------------------------------
# Application / Observability
# ------------------------------------------------------------
LOG_LEVEL=INFO
# Set to "true" for JSON structured logs (recommended in production)
LOG_JSON=false

# Development flags (set to "true" to skip real infrastructure)
USE_NULL_MEMORY=false
USE_NULL_MEDIA=false
